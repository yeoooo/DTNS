{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dtns/contracts/ai_execution_state.schema.json",
  "title": "AI Execution State",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "policy_fingerprint",
    "primary_model",
    "fallback_model",
    "preferred_model",
    "circuit_state",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "primary_model": { "type": "string", "minLength": 1 },
    "fallback_model": { "type": "string", "minLength": 1 },
    "preferred_model": { "type": "string", "minLength": 1 },
    "circuit_state": { "type": "string", "enum": ["closed", "open"] },
    "opened_at": { "type": ["string", "null"], "format": "date-time" },
    "open_reason": {
      "type": ["string", "null"],
      "enum": [null, "transient_api_exhausted"]
    },
    "primary_failures": { "type": "integer", "minimum": 0 },
    "fallback_successes": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
