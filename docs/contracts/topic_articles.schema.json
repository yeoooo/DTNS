{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dtns/contracts/topic_articles.schema.json",
  "title": "Topic Articles",
  "type": "object",
  "required": ["schema_version", "generated_at", "topic", "articles"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "topic": {
      "type": "string",
      "enum": ["technology", "backend", "qa"]
    },
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "title",
          "canonical_url",
          "published_at",
          "tags",
          "technologies",
          "domains",
          "ai_metadata",
          "classification"
        ],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "title": { "type": "string" },
          "canonical_url": { "type": "string", "format": "uri" },
          "summary": { "type": "string" },
          "published_at": { "type": ["string", "null"], "format": "date-time" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "technologies": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "domains": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "ai_metadata": {
            "type": "object",
            "required": ["model", "confidence"],
            "properties": {
              "model": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "rationale": { "type": "string" }
            },
            "additionalProperties": false
          },
          "classification": {
            "type": "object",
            "required": ["matched_rules"],
            "properties": {
              "matched_rules": {
                "type": "array",
                "items": { "type": "string" }
              },
              "score": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
