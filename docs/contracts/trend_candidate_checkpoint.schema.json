{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dtns/contracts/trend_candidate_checkpoint.schema.json",
  "title": "Trend Candidate Checkpoint",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "topic",
    "input_fingerprint",
    "policy_fingerprint",
    "checkpoint_id",
    "phase",
    "source_ids",
    "model",
    "generated_at",
    "candidates"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "topic": {
      "type": "string",
      "enum": ["technology", "backend", "qa"]
    },
    "input_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "policy_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checkpoint_id": {
      "type": "string",
      "pattern": "^(map|reduce)-[a-z0-9-]+$"
    },
    "phase": {
      "type": "string",
      "enum": ["map", "reduce"]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "model": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "candidates": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "importance",
          "summary",
          "why_it_matters",
          "article_ids",
          "keywords"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1, "maxLength": 120 },
          "importance": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
          "why_it_matters": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "article_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "keywords": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 80 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
