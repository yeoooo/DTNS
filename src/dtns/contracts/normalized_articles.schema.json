{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dtns/contracts/normalized_articles.schema.json",
  "title": "Normalized Articles",
  "type": "object",
  "required": ["schema_version", "generated_at", "articles"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "title",
          "canonical_url",
          "published_at",
          "collected_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Deterministic stable ID, preferably derived from canonical_url."
          },
          "source": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": ["rss", "atom", "github_release", "api", "html"]
          },
          "title": { "type": "string", "minLength": 1 },
          "canonical_url": { "type": "string", "format": "uri" },
          "original_url": { "type": "string", "format": "uri" },
          "summary": { "type": "string" },
          "author": { "type": "string" },
          "published_at": { "type": ["string", "null"], "format": "date-time" },
          "collected_at": { "type": "string", "format": "date-time" },
          "language": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
